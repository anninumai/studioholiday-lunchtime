---
import { getImage } from "astro:assets";
import pinkCanvas from "../assets/site/msg/pink-canvas-bg-v2.webp";
import bgPatternSource from "../assets/site/studio/bg_pattern.webp";
import greenCanvas from "../assets/site/textures/green-canvas-bg-v2.webp";
import { content } from "../data/content";
import { withBase } from "../lib/withBase";
import "../styles/global.css";

const { title, description } = content.meta;
const [
  hero,
  norenLogo,
  bgPattern,
  bgPatternMobile,
  bgPinkMobile,
  bgCanvasMobile,
] = await Promise.all([
  getImage({ src: content.hero.src, width: 1200, format: "webp", quality: 80 }),
  getImage({
    src: content.noren.logo,
    width: 912,
    format: "webp",
    quality: 80,
  }),
  getImage({ src: bgPatternSource, width: 1920, format: "webp", quality: 75 }),
  getImage({ src: bgPatternSource, width: 768, format: "webp", quality: 75 }),
  getImage({ src: pinkCanvas, width: 768, format: "webp", quality: 75 }),
  getImage({ src: greenCanvas, width: 768, format: "webp", quality: 75 }),
]);
// Absolute URLs for OG/canonical require `site` in astro.config.ts. Guard so a
// missing `site` (e.g. mid-config) degrades gracefully instead of throwing.
const ogImage = Astro.site ? new URL(hero.src, Astro.site).href : hero.src;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
const fontFaces = `@font-face{
  font-family:"Zen Maru Gothic";
  font-style:normal;
  font-weight:500;
  font-display:swap;
  src:url("${withBase("/fonts/zen-maru-500-subset.woff2")}") format("woff2");
}
@font-face{
  font-family:"Zen Maru Gothic";
  font-style:normal;
  font-weight:700;
  font-display:swap;
  src:url("${withBase("/fonts/zen-maru-700-subset.woff2")}") format("woff2");
}`;
// Section backgrounds are generated here because CSS url() references cannot use
// Astro's image pipeline directly.
const bgVars = `:root{
  --bg-pattern:url("${bgPattern.src}");
  --bg-pattern-mobile:url("${bgPatternMobile.src}");
  --bg-canvas:url("${greenCanvas.src}");
  --bg-canvas-mobile:url("${bgCanvasMobile.src}");
  --bg-pink:url("${pinkCanvas.src}");
  --bg-pink-mobile:url("${bgPinkMobile.src}");
}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* Flag that JS is available: appear-animations only hide content when they
        can reveal it, so nothing stays invisible if the script fails to run. */
    }
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />

    {/* Base-aware font and background URLs for GitHub Pages project sites. */}
    <style is:inline set:html={fontFaces}></style>
    <style is:inline set:html={bgVars}></style>

    <link rel="preload" as="image" href={norenLogo.src} fetchpriority="high" />
  </head>
  <body>
    <slot />
  </body>
</html>
