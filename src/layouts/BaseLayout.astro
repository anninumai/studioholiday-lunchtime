---
import { content } from "../data/content";
import { withBase } from "../lib/withBase";
import "../styles/global.css";

const { title, description } = content.meta;
// Absolute URLs for OG/canonical require `site` in astro.config.ts. Guard so a
// missing `site` (e.g. mid-config) degrades gracefully instead of throwing.
const heroSrc = withBase(content.hero.src);
const ogImage = Astro.site ? new URL(heroSrc, Astro.site).href : heroSrc;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
// Section background images live in global.css via url(); pass them through the
// base as :root custom properties so they resolve under a project subpath too.
const bgVars = `:root{
  --bg-pattern:url("${withBase("/assets/studio/bg_pattern.webp")}");
  --bg-message:url("${withBase("/assets/studio/message_bg.webp")}");
  --bg-access:url("${withBase("/assets/studio/access_bg.webp")}");
}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* Flag that JS is available: appear-animations only hide content when they
        can reveal it, so nothing stays invisible if the script fails to run. */
    }
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />

    {/* Self-hosted, pre-subset fonts (served as-is from public/). */}
    <link rel="stylesheet" href={withBase("/fonts/zen-local.css")} />

    {/* Base-aware background-image URLs for global.css (see bgVars above). */}
    <style is:inline set:html={bgVars}></style>

    {
      /* LCP preload parked with <HeroZoom /> (see index.astro): the noren-hero
      test renders CSS panels + a <video>, so hero.webp is no longer above the
      fold. Restore this if reverting to HeroZoom. */
    }
    {
      /*
    <link rel="preload" as="image" href={content.hero.src} fetchpriority="high" />
    */
    }
  </head>
  <body>
    <slot />
  </body>
</html>
