---
import { content } from "../data/content";
// 5 paragraphs. Line 1 = lead tagline, line 4 = long emotional line (see the
// message typography in global.css). Modifiers are assigned by index. A line may
// contain "\n" for controlled breaks (line 4), rendered as <br> below.
const lines = content.message;
const modifier = (i: number): string =>
  i === 0 ? " msg--lead" : i === 3 ? " msg--long" : "";
---

<section class="message appear--hero">
  <div class="message-inner">
    {
      lines.map((line, i) => (
        <p class={`msg${modifier(i)}`}>
          {line.split("\n").map((seg, j) => (
            <Fragment>
              {j > 0 && <br />}
              {seg}
            </Fragment>
          ))}
        </p>
      ))
    }
  </div>
</section>
