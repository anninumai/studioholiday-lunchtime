---
import { content } from "../data/content";
import { withBase } from "../lib/withBase";
const { join, card, carousel } = content;
// The card is titled with the みんなでごはん会 brand logo (same mark as the footer).
const logo = content.footer.logo;
---

<section class="access">
  <div class="card appear">
    <div class="card-main">
      <div class="card-info">
        <img
          class="c-logo"
          src={withBase(logo.src)}
          width={logo.width}
          height={logo.height}
          alt="みんなでごはん会"
          loading="lazy"
          decoding="async"
        />
        <p class="c-line">
          <img class="c-icon" src={withBase("/assets/icons/clock-4.png")} alt="" width="20" height="20" loading="lazy" decoding="async" />
          <span>{card.time}</span>
        </p>
        <p class="c-line">
          <img class="c-icon" src={withBase("/assets/icons/map-pin-house.png")} alt="" width="20" height="20" loading="lazy" decoding="async" />
          <span>{card.addressLines[0]}<br />{card.addressLines[1]}<br />{card.addressLines[2]}</span>
        </p>
        <p class="c-line">
          <span class="c-icon" aria-hidden="true"></span>
          <span>{card.access}</span>
        </p>
        <p class="c-line">
          <span class="c-icon" aria-hidden="true"></span>
          <span><a href={card.mapUrl} target="_blank" rel="noopener">{card.mapLabel}</a></span>
        </p>
      </div>

      <div class="card-carousel">
        <gohan-carousel>
          <div
            class="carousel"
            role="group"
            aria-roledescription="カルーセル"
            aria-label="新大久保駅からの道順"
          >
            <div class="viewport">
              <div class="track">
                {
                  carousel.map((s) => (
                    <div class="slide">
                      <img
                        src={withBase(s.src)}
                        width={s.width}
                        height={s.height}
                        alt={s.alt}
                        loading="lazy"
                        decoding="async"
                      />
                      <p class="cap">{s.caption}</p>
                    </div>
                  ))
                }
              </div>
            </div>
            <div class="nav">
              <button class="prev" type="button" aria-label="前へ">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path
                    d="M13 4l-6 6 6 6"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>
              <button class="next" type="button" aria-label="次へ">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path
                    d="M7 4l6 6-6 6"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>
            </div>
          </div>
        </gohan-carousel>
      </div>
    </div>

    <p class="card-note">{join[0]}<br />{join[1]}</p>
  </div>
</section>
