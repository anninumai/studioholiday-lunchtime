---
import { Image } from "astro:assets";
import clockIcon from "../assets/site/icons/clock-4.png";
import mapIcon from "../assets/site/icons/map-pin-house.png";
import { content } from "../data/content";
const { join, card, carousel } = content;
// The card is titled with the みんなでごはん会 brand logo (same mark as the footer).
const logo = content.footer.logo;
---

<section class="access">
  <div class="card appear">
    <Image
      class="c-logo"
      src={logo.src}
      alt="みんなでごはん会"
      widths={[148, 210, 235]}
      sizes="210px"
      format="webp"
      quality={80}
      loading="lazy"
      decoding="async"
    />

    <div class="card-main">
      <div class="card-info">
        <p class="c-line">
          <Image
            class="c-icon"
            src={clockIcon}
            alt=""
            width={20}
            height={20}
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <span>{card.time}</span>
        </p>
        <p class="c-line">
          <Image
            class="c-icon"
            src={mapIcon}
            alt=""
            width={20}
            height={20}
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <span
            >{card.addressLines[0]}<br />{card.addressLines[1]}<br />{
              card.addressLines[2]
            }</span
          >
        </p>
        <p class="c-line">
          <span class="c-icon" aria-hidden="true"></span>
          <span>{card.access}</span>
        </p>
        <p class="c-line">
          <span class="c-icon" aria-hidden="true"></span>
          <span
            ><a href={card.mapUrl} target="_blank" rel="noopener"
              >{card.mapLabel}</a
            ></span
          >
        </p>
      </div>

      <div class="card-carousel">
        <gohan-carousel>
          <div
            class="carousel"
            role="group"
            aria-roledescription="カルーセル"
            aria-label="新大久保駅からの道順"
          >
            <div class="viewport">
              <div class="track">
                {
                  carousel.map((s) => (
                    <div class="slide">
                      <Image
                        src={s.src}
                        alt={s.alt}
                        widths={[360, 640, 960, 1200]}
                        sizes="(max-width: 540px) 100vw, 640px"
                        format="webp"
                        quality={80}
                        loading="lazy"
                        decoding="async"
                      />
                      <p class="cap">{s.caption}</p>
                    </div>
                  ))
                }
              </div>
            </div>
            <div class="nav" aria-label="スライドを選択">
              {
                carousel.map((_, index) => (
                  <button
                    class="dot"
                    type="button"
                    data-slide={index}
                    aria-label={`${index + 1}枚目を表示`}
                    aria-current={index === 0 ? "true" : "false"}
                  />
                ))
              }
            </div>
          </div>
        </gohan-carousel>
      </div>
    </div>

    <p class="card-note">
      {
        join.map((line, index) => (
          <Fragment>
            {index > 0 && <br />}
            {line.split("|").map((segment, segmentIndex) => (
              <Fragment>
                {segmentIndex > 0 && <br class="br-sp" />}
                {segment}
              </Fragment>
            ))}
          </Fragment>
        ))
      }
    </p>
  </div>
</section>
