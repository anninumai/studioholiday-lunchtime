---
import { Image } from "astro:assets";
import fork from "../assets/site/photo/holiday-fork.png";
import mouth from "../assets/site/photo/holiday-mouth.png";
import spoon from "../assets/site/photo/holiday-spoon.png";
import { content } from "../data/content";
const { photo } = content;
---

<section class="photo">
  <div class="photo-art appear">
    <Image
      class="photo-base"
      src={photo.src}
      alt={photo.alt}
      widths={[480, 960, 1440]}
      sizes="(max-width: 540px) 100vw, 920px"
      format="webp"
      quality={80}
      loading="lazy"
      decoding="async"
    />
    <Image
      class="photo-part photo-fork"
      src={fork}
      alt=""
      aria-hidden="true"
      widths={[128, 256, 384]}
      sizes="12vw"
      format="webp"
      quality={80}
      loading="lazy"
      decoding="async"
    />
    <Image
      class="photo-part photo-spoon"
      src={spoon}
      alt=""
      aria-hidden="true"
      widths={[128, 256, 384]}
      sizes="14vw"
      format="webp"
      quality={80}
      loading="lazy"
      decoding="async"
    />
    <Image
      class="photo-part photo-mouth"
      src={mouth}
      alt=""
      aria-hidden="true"
      widths={[120, 240, 360]}
      sizes="16vw"
      format="webp"
      quality={80}
      loading="lazy"
      decoding="async"
    />
  </div>
  <p class="speech">{photo.speech}</p>
</section>
