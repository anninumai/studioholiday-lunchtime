---
import { content } from "../data/content";
import { withBase } from "../lib/withBase";
const { photo } = content;
---

<section class="photo">
  <div class="photo-art appear">
    <img
      class="photo-base"
      src={withBase(photo.src)}
      width={photo.width}
      height={photo.height}
      alt={photo.alt}
      loading="lazy"
      decoding="async"
    />
    <img
      class="photo-part photo-fork"
      src={withBase("/assets/photo/holiday-fork.png")}
      width="608"
      height="1519"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
    />
    <img
      class="photo-part photo-spoon"
      src={withBase("/assets/photo/holiday-spoon.png")}
      width="806"
      height="1485"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
    />
    <img
      class="photo-part photo-mouth"
      src={withBase("/assets/photo/holiday-mouth.png")}
      width="815"
      height="349"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
    />
  </div>
  <p class="speech">{photo.speech}</p>
</section>
