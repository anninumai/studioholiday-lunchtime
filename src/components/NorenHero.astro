---
import { getImage } from "astro:assets";
import mobilePosterSource from "../assets/site/intro-poster-mobile.jpg";
import posterSource from "../assets/site/studio/intro-poster.jpg";
import { content } from "../data/content";
import { withBase } from "../lib/withBase";

const { noren, video } = content;
const [logo, desktopPoster, mobilePoster] = await Promise.all([
  getImage({ src: noren.logo, width: 912, format: "webp", quality: 80 }),
  getImage({
    src: posterSource,
    width: 1280,
    height: 720,
    format: "webp",
    quality: 75,
  }),
  getImage({
    src: mobilePosterSource,
    width: 540,
    height: 960,
    format: "webp",
    quality: 75,
  }),
]);
const posterVars = `--video-poster:url("${desktopPoster.src}");--video-poster-mobile:url("${mobilePoster.src}")`;

// A traditional noren drawn as a single SVG: one cloth joined across the top,
// with 2 slits splitting the lower part into 3 equal-width flaps (their total is
// wider than the viewport, so the outer ones overflow). One SVG avoids a seam and
// stays crisp when zoomed. Only the flaps skew (independently) in <noren-cloth>;
// the top band is fixed. All geometry is in percent with NO viewBox, so the SVG's
// user space equals CSS pixels — the skew lean is then identical on every screen
// (a stretched viewBox would make it vary with aspect ratio). White, no shadow.
const SLIT = 1; // slit width, percent of width (~12px at 1280w)
const BAND = 32; // connected top band height, percent (the slits start below this)
const BAND_TOP = 3; // cloth top; the small チチ marks stick up from here
// チチ: a row of small tabs along the top edge — the subtle dashed top of a hung noren.
const DASH_N = 14;
// Keep the desktop visual weight on every viewport. Percentage width made the
// same source geometry collapse to roughly 5px on phones.
const DASH_W = 18; // desktop source width, CSS/SVG pixels
const dashes = Array.from({ length: DASH_N }, (_, i) => ({
  x: ((i + 0.5) / DASH_N) * 100,
}));
const OVERLAP = 1; // flaps tuck this far (percent) under the band so the join can't gap
// Three EQUAL-width flaps, each as wide as the former centre panel (50%). Their total
// is wider than the viewport, so the outer flaps bleed off the left/right edges. The
// centre flap stays at 25–75%. On mobile the enlarged emblem deliberately crosses
// both slits; each flap owns its clipped fragment and moves it independently.
const FLAP_W = 50; // each flap, percent of width
const CLOTH_W = 3 * FLAP_W + 2 * SLIT; // 152 — wider than the viewport (outer flaps overflow)
const flapStart = (100 - CLOTH_W) / 2; // -26 (cloth is centred, outer flaps off-screen)
const flapY = BAND - OVERLAP;
const flapH = 100 - flapY;
const flaps = [0, 1, 2].map((i) => ({
  x: flapStart + i * (FLAP_W + SLIT),
  w: FLAP_W,
}));
// Emblem box (percent). Sized by WIDTH (a fixed fraction of the viewport width, the
// same basis as the slits), so it stays a consistent size across aspect ratios and
// is centred via meet. CSS widens this box on mobile so it crosses both slits.
// Native SVG percentage attributes are used (instead of responsive CSS geometry)
// so every browser computes the same exact 50% centre: 12 + 76 / 2 = 50.
const logoX = 12;
const logoW = 76;
const logoY = 5;
const logoH = 86;
---

<section class="noren-hero">
  <div class="noren-pin">
    {
      /* Revealed payoff: the centered logo video (blur -> focus via the shared
        <video-stage> island), uncovered as the cloth lifts. Sits behind it. */
    }
    <video-stage data-play-at="0.5">
      <div class="noren-video" style={posterVars}>
        <video
          data-src={`${withBase(video.desktopSrc)}#t=0.01`}
          data-mobile-src={`${withBase(video.mobileSrc)}#t=0.01`}
          width={video.width}
          height={video.height}
          autoplay
          muted
          loop
          playsinline
          preload="auto"></video>
      </div>

      {
        /* Mobile scroll cue — visible at the page top and hidden while scrolling below. */
      }
      <div class="scroll-hint is-shown" aria-hidden="true">
        <span class="scroll-hint-label">スクロール</span>
        <svg class="scroll-hint-arrow" viewBox="0 0 24 32" aria-hidden="true">
          <path d="M12 2c-1 7 1 14 0 23M5 19l7 8 7-8"></path>
        </svg>
      </div>
    </video-stage>

    {
      /* Foreground cloth. The wrapper scroll-zooms (approach) then lifts (reveal)
        via pure CSS; each panel sways on pointer/tap via <noren-cloth> (JS). */
    }
    <noren-cloth>
      <svg class="noren" role="img" aria-label={noren.alt}>
        <defs>
          <pattern
            id="noren-fabric"
            patternUnits="userSpaceOnUse"
            width="350"
            height="325"
          >
            <rect width="350" height="325" fill="var(--color-surface)"></rect>
            <image
              href={withBase("/assets/noren-texture.webp")}
              width="350"
              height="325"
              opacity="0.42"
              preserveAspectRatio="none"
            />
          </pattern>
          {
            /* Fixed hems keep each irregular edge proportional to its flap at every
              viewport size without per-frame filter work. */
          }
          <clipPath id="noren-hem-0" clipPathUnits="objectBoundingBox">
            <path
              d="M0 0H1V.966C.91.984.82.954.72.974C.61.995.51.963.4.981C.29.997.17.956 0 .976Z"
            ></path>
          </clipPath>
          <clipPath id="noren-hem-1" clipPathUnits="objectBoundingBox">
            <path
              d="M0 0H1V.978C.89.956.78.991.67.971C.56.951.46.986.35.968C.23.948.12.989 0 .97Z"
            ></path>
          </clipPath>
          <clipPath id="noren-hem-2" clipPathUnits="objectBoundingBox">
            <path
              d="M0 0H1V.969C.9.992.8.96.69.979C.58.997.48.955.37.975C.25.995.13.962 0 .983Z"
            ></path>
          </clipPath>
          {
            /* Separate clips cut one full-size emblem copy into the fixed band and
            three flap fragments. All fragments share the same source geometry. */
          }
          {
            flaps.map((f, i) => (
              <clipPath
                id={`noren-flap-clip-${i}`}
                clipPathUnits="userSpaceOnUse"
              >
                <rect
                  x={`${f.x}%`}
                  y={`${flapY}%`}
                  width={`${f.w}%`}
                  height={`${flapH}%`}
                />
              </clipPath>
            ))
          }
          <clipPath id="noren-band-clip" clipPathUnits="userSpaceOnUse">
            <rect
              x={`${flapStart}%`}
              y={`${BAND_TOP}%`}
              width={`${CLOTH_W}%`}
              height={`${BAND - BAND_TOP + 1}%`}></rect>
          </clipPath>
        </defs>
        {
          /* Each flap and its clipped logo fragment share one transform. The pivot
            is fixed by CSS at BAND (32%), so the logo stays joined to the band at
            that horizontal boundary while separating below it. */
        }
        {
          flaps.map((f, i) => (
            <g class="noren-panel">
              <rect
                class={`noren-cloth-shape noren-cloth-shape-${i}`}
                x={`${f.x}%`}
                y={`${flapY}%`}
                width={`${f.w}%`}
                height={`${flapH}%`}
              />
              <image
                class="noren-emblem"
                href={logo.src}
                x={`${logoX}%`}
                y={`${logoY}%`}
                width={`${logoW}%`}
                height={`${logoH}%`}
                preserveAspectRatio="xMidYMid meet"
                clip-path={`url(#noren-flap-clip-${i})`}
              />
            </g>
          ))
        }
        {
          /* Connected top band (static). Its top sits below the rod (BAND_TOP) so the
          cloth reads as hanging in front of the rod. */
        }
        <g class="noren-band">
          <rect
            class="noren-cloth-shape"
            x={`${flapStart}%`}
            y={`${BAND_TOP}%`}
            width={`${CLOTH_W}%`}
            height={`${BAND - BAND_TOP}%`}></rect>
          <image
            class="noren-emblem"
            href={logo.src}
            x={`${logoX}%`}
            y={`${logoY}%`}
            width={`${logoW}%`}
            height={`${logoH}%`}
            preserveAspectRatio="xMidYMid meet"
            clip-path="url(#noren-band-clip)"
          />
        </g>
        {/* チチ: small tabs along the top edge (the noren's hanging marks). */}
        <g class="noren-chichi">
          {
            dashes.map((d) => (
              <rect
                x={`${d.x}%`}
                y="0"
                width={DASH_W}
                height="4%"
                rx="2"
                transform={`translate(${-DASH_W / 2} 0)`}
              />
            ))
          }
        </g>
        {/* Desktop uses the original thick, hand-drawn hanging-tab artwork. */}
        <image
          class="noren-tabs-art"
          href={withBase(noren.tabs)}
          x={`${flapStart}%`}
          y="-3.14vw"
          width={`${CLOTH_W}%`}
          height="6.28vw"
          preserveAspectRatio="xMidYMin meet"
        />
      </svg>
    </noren-cloth>
  </div>
</section>
