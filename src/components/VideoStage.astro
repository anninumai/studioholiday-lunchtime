---
import { content } from "../data/content";
import { withBase } from "../lib/withBase";
const { video } = content;
---

<video-stage>
  <section class="video-stage">
    <div class="video-pin">
      {
        /* Played from the top by <video-stage> on scroll-in (not autoplay, so it
          isn't finished off-screen before the viewer arrives). */
      }
      <video
        class="appear--video"
        width={video.width}
        height={video.height}
        muted
        playsinline
        preload="none"
      >
        <source
          src={withBase(video.mobileSrc)}
          media="(max-width: 767px)"
          type="video/mp4"
        />
        <source src={withBase(video.desktopSrc)} type="video/mp4" />
      </video>
    </div>
  </section>
</video-stage>
