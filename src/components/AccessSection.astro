---
import { content } from "../data/content";
const { join, card, carousel } = content;
---

<p class="abs join appear">{join[0]}<br />{join[1]}</p>

<div class="abs card appear">
  <div class="card-info">
    <p class="name">{card.name}</p>
    <p>{card.time}</p>
    <p class="gap">{card.address}</p>
    <p>{card.tagline}</p>
    <p class="gap">{card.access}</p>
    <p>
      <a href={card.mapUrl} target="_blank" rel="noopener">{card.mapLabel}</a>
    </p>
  </div>

  <gohan-carousel>
    <div class="carousel">
      <div class="frame">
        <div class="track">
          {
            carousel.slides.map((s) => (
              <img src={s.src} width="600" height="325" alt={s.alt} />
            ))
          }
        </div>
      </div>
      <p class="cap">{carousel.caption}</p>
      <div class="controls">
        <button class="nav prev" type="button" aria-label="前へ">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M13 4l-6 6 6 6"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <button class="nav next" type="button" aria-label="次へ">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M7 4l6 6-6 6"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="dots">
          <span class="dot active"></span><span class="dot"></span><span
            class="dot"></span>
        </div>
      </div>
    </div>
  </gohan-carousel>
</div>
