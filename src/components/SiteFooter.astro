---
import { content } from "../data/content";
const { logo, wordmark } = content.footer;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-row">
      <div class="footer-logos">
        <img
          class="flogo"
          src={logo.src}
          width={logo.width}
          height={logo.height}
          alt={logo.alt}
          loading="lazy"
          decoding="async"
        />
        <img
          class="fword"
          src={wordmark.src}
          width={wordmark.width}
          height={wordmark.height}
          alt={wordmark.alt}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
    <div class="footer-divider"></div>
  </div>
</footer>
