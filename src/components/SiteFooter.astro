---
import { content } from "../data/content";
// The footer is the STUDIO HOLIDAY logo followed by the "/ K,D,C,,," credit.
// The logo is inlined as raw SVG so it can be recolored via CSS `color` (it
// defaults to its own gray). This replaces the old みんなでごはん会 logo + the
// "by HOLIDAY KITCHEN / K,D,C,,," wordmark image (KDC is now the credit text).
import logoSvg from "../assets/studio-holiday-logo.svg?raw";
const { credit } = content.footer;
---

<footer class="footer">
  <div class="footer-inner">
    <span class="sh-logo" set:html={logoSvg}></span>
    <span class="sh-kdc">{credit}</span>
  </div>
</footer>
